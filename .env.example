# Database
DATABASE_URL=postgresql://photoportugal:password@localhost:5432/photoportugal

# NextAuth
NEXTAUTH_URL=https://photoportugal.com
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRO_PRICE_ID=price_your-pro-price-id
STRIPE_PREMIUM_PRICE_ID=price_your-premium-price-id
STRIPE_FEATURED_PRICE_ID=price_your-featured-price-id
STRIPE_VERIFIED_PRICE_ID=price_your-verified-price-id

# SMTP (Email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Twilio (Phone Verification)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SID=your-twilio-verify-sid

# Cron
CRON_SECRET=generate-with-openssl-rand-hex-32

# File Uploads
UPLOAD_DIR=/var/www/photoportugal/uploads
